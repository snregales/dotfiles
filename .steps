    1  sudo apt install zsh curl git vim tree ranger fonts-firacode
    2  sh -c "$curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" 
    3  cd .oh-my-zsh/custom/plugins
    4  git submodule add -f https://github.com/zsh-users/zsh-syntax-highlighting.git
    5  git submodule add -f https://github.com/zsh-users/zsh-autosuggestions.git
    6  cd ../themes
    7  git submodule add -f https://github.com/Powerlevel9k/powerlevel9k.git
   19  md .local/share/fonts
   20  cd .local/share/fonts
   22  wget https://github.com/powerline/powerline/raw/develop/font/PowerlineSymbols.otf
   23  wget https://github.com/powerline/powerline/raw/develop/font/10-powerline-symbols.conf
   26  md ~/.config/fontconfig/conf.d/
   27  mv 10-powerline-symbols.conf ~/.config/fontconfig/conf.d
   30  fc-cache -vf ~/.local/share/fonts/
